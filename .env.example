# ─── Application ───────────────────────────────────────────────
ENV=dev                          # dev | prod
SECRET_KEY=change-me-in-production

# ─── Base de données PostgreSQL ────────────────────────────────
# En prod (Render), DATABASE_URL est injecté automatiquement — ignorez ces variables.
DB_NAME=dah_db
DB_USER=dah
DB_PASSWORD=dah_password
DB_HOST=db
DB_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────
# Non utilisé en prod pour l'instant (CELERY_TASK_ALWAYS_EAGER=True dans prod.py,
# pas de worker/Redis déployé sur le plan gratuit Render).
REDIS_URL=redis://redis:6379/0

# ─── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ─── Email SMTP — Brevo (plan gratuit, 300 emails/jour) ─────────
# Clé SMTP à générer sur https://app.brevo.com/settings/keys/smtp
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@dataafriquehub.com

# ─── CORS ───────────────────────────────────────────────────────
# En prod : mettre l'URL Vercel du frontend (https://xxx.vercel.app)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Render (prod uniquement) ───────────────────────────────────
# CSRF_TRUSTED_ORIGINS=https://votre-domaine.onrender.com

# ─── Frontend Next.js ───────────────────────────────────────────
# En prod : NEXT_PUBLIC_API_BASE_URL = URL du backend Render (https://xxx.onrender.com)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
